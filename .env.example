APP_NAME="Shopify Section Generator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database.sqlite
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# ============================================
# AI Provider Configuration
# ============================================
# Default provider: openai (recommended), gemini, openrouter, or grok
AI_PROVIDER=openai

# Only add API keys for the provider(s) you want to use.
# The app will automatically detect available providers.

# ============================================
# OpenAI (GPT) - Recommended
# https://platform.openai.com/api-keys
# Models: gpt-4o (recommended), gpt-4-turbo, gpt-3.5-turbo
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ============================================
# Google Gemini - Fast & Cost-effective
# https://aistudio.google.com/app/apikey
# Models: gemini-2.0-flash (recommended), gemini-2.0-flash-lite, gemini-2.5-flash
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# OpenRouter - Multi-provider Access
# https://openrouter.ai/keys
# Provides access to: Claude, Llama, Deepseek, and more
# Models: deepseek/deepseek-chat (recommended), openai/gpt-4o, anthropic/claude-3.5-sonnet
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat

# ============================================
# Grok (xAI) - Latest Open-Source Based Models
# https://console.x.ai
# Models: grok-2-latest (recommended)
# ============================================
GROK_API_KEY=your-grok-api-key-here
GROK_MODEL=grok-2-latest

# ============================================
# Optional: Mail Configuration
# (Not used in basic setup)
# ============================================
MAIL_DRIVER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=